<view class="page" wx:if="{{vehicle}}">

  <!-- 图片轮播 -->
  <view class="swiper-wrap">
    <swiper class="image-swiper" circular bindchange="onSwiperChange">
      <swiper-item wx:for="{{vehicle.images}}" wx:key="*this" wx:for-index="idx">
        <image class="swiper-image" src="{{item}}" mode="aspectFill"
          data-index="{{idx}}" bindtap="onImageTap" />
      </swiper-item>
    </swiper>
    <view class="image-counter">
      <text>{{currentImageIndex + 1}}/{{vehicle.images.length}}</text>
    </view>
  </view>

  <!-- 价格 & 标题 -->
  <view class="info-card">
    <view class="price-row">
      <view class="price-wrap">
        <text class="price-num">{{vehicle.priceWan}}</text>
        <text class="price-unit">万元</text>
      </view>
      <view class="condition-tags">
        <text
          wx:for="{{vehicle.conditionTags}}"
          wx:key="label"
          class="cond-tag cond-tag-{{item.type}}"
        >{{item.label}}</text>
      </view>
    </view>
    <text class="vehicle-title">{{vehicle.brand}} {{vehicle.model}}</text>
  </view>

  <!-- 4格关键参数 -->
  <view class="params-card">
    <view class="param-item">
      <text class="param-value">{{vehicle.mileageW}}万</text>
      <text class="param-label">里程(km)</text>
    </view>
    <view class="param-divider"></view>
    <view class="param-item">
      <text class="param-value">{{vehicle.year}}</text>
      <text class="param-label">年份</text>
    </view>
    <view class="param-divider"></view>
    <view class="param-item">
      <text class="param-value">{{vehicle.transmission}}</text>
      <text class="param-label">变速箱</text>
    </view>
    <view class="param-divider"></view>
    <view class="param-item">
      <text class="param-value">{{vehicle.displacement}}</text>
      <text class="param-label">排量</text>
    </view>
  </view>

  <!-- 车辆详情（可折叠） -->
  <view class="detail-card">
    <view class="detail-header" bindtap="onToggleDesc">
      <text class="detail-title">车辆详情</text>
      <text class="detail-arrow {{descExpanded ? 'arrow-up' : ''}}">▼</text>
    </view>
    <view class="detail-rows">
      <view class="detail-row">
        <text class="detail-label">颜色</text>
        <text class="detail-value">{{vehicle.color}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">城市</text>
        <text class="detail-value">{{vehicle.city}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">状态</text>
        <text class="detail-value text-success">在售</text>
      </view>
    </view>
    <view class="desc-wrap {{descExpanded ? 'desc-expanded' : ''}}">
      <text class="desc-text">{{vehicle.description}}</text>
    </view>
    <view class="desc-toggle" bindtap="onToggleDesc">
      <text class="desc-toggle-text">{{descExpanded ? '收起' : '查看完整描述'}}</text>
      <text class="desc-toggle-arrow {{descExpanded ? 'arrow-up' : ''}}">▼</text>
    </view>
  </view>

  <!-- 卖家信息 -->
  <view class="seller-card">
    <view class="seller-header">
      <text class="seller-title">卖家信息</text>
    </view>
    <view class="seller-info">
      <view class="seller-avatar">
        <text class="seller-avatar-icon">🏪</text>
      </view>
      <view class="seller-meta">
        <text class="seller-name">官方认证商家</text>
        <text class="seller-desc">已认证 · 响应迅速</text>
      </view>
      <view class="seller-badge">
        <text class="seller-badge-text">认证</text>
      </view>
    </view>
  </view>

  <view class="bottom-placeholder"></view>

</view>

<!-- 底部操作栏 -->
<view class="action-bar" wx:if="{{vehicle}}">
  <view class="action-favorite {{isFavorite ? 'action-favorite-active' : ''}}" bindtap="onToggleFavorite">
    <text class="action-icon">{{isFavorite ? '❤' : '♡'}}</text>
    <text class="action-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
  </view>
  <view class="action-consult btn btn-outline" bindtap="onConsult">
    <text>联系销售</text>
  </view>
  <view class="action-book btn btn-primary" bindtap="onBookVisit">
    <text>预约看车</text>
  </view>
</view>
