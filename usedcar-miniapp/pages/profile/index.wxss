page {
  background: var(--color-bg-page);
}
.container {
  min-height: 100vh;
}

/* 用户信息头部 */
.user-header {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  padding: 80rpx 40rpx 60rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255,255,255,0.6);
  flex-shrink: 0;
}
.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-icon { font-size: 60rpx; }
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}
.phone {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}
.arrow {
  font-size: 40rpx;
  color: rgba(255,255,255,0.7);
}

/* 数据统计行 */
.stats-row {
  background: var(--color-bg-card);
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.stat-num {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-primary);
}
.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
}
.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--color-divider);
}

/* 开发测试登录 */
.dev-login-area {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
}
.dev-login-btn {
  font-size: 26rpx;
  color: #fa8c16;
  padding: 16rpx 32rpx;
  border: 1rpx dashed #fa8c16;
  border-radius: 32rpx;
  background: var(--color-bg-card);
}

/* 菜单列表 */
.menu-list {
  background: var(--color-bg-card);
  margin: 24rpx 0;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
  border-bottom: 1rpx solid var(--color-divider);
  gap: 24rpx;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}
.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text-primary);
}
.menu-arrow {
  font-size: 36rpx;
  color: var(--color-border);
}

/* 退出登录 */
.logout-area {
  margin: 0 0 60rpx;
  display: flex;
  justify-content: center;
}
.logout-btn {
  font-size: 30rpx;
  color: var(--color-danger);
  padding: 24rpx 80rpx;
  background: var(--color-bg-card);
  border-radius: 48rpx;
  border: 1rpx solid #ffccc7;
}
