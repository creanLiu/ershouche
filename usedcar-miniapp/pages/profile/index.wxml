<view class="container">
  <!-- 用户信息区 -->
  <view class="user-header">
    <block wx:if="{{isLoggedIn}}">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view class="user-info">
        <text class="nickname">{{userInfo.nickName}}</text>
        <text class="phone">{{userInfo.phone}}</text>
      </view>
    </block>
    <block wx:else>
      <view class="avatar-placeholder" bindtap="onGoLogin">
        <text class="avatar-icon">👤</text>
      </view>
      <view class="user-info" bindtap="onGoLogin">
        <text class="nickname">点击登录</text>
        <text class="phone">登录后享受更多服务</text>
      </view>
    </block>
    <text class="arrow">›</text>
  </view>

  <!-- 数据统计行 -->
  <view class="stats-row">
    <view class="stat-item" bindtap="onGoBrowseHistory">
      <text class="stat-num">{{browseCount}}</text>
      <text class="stat-label">浏览</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onGoFavorite">
      <text class="stat-num">{{favoriteCount}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onGoOrder">
      <text class="stat-num">{{orderCount}}</text>
      <text class="stat-label">订单</text>
    </view>
  </view>

  <!-- 开发测试：模拟登录 -->
  <view class="dev-login-area" wx:if="{{!isLoggedIn}}">
    <text class="dev-login-btn" bindtap="onDevLogin">🛠 模拟登录（开发测试）</text>
  </view>

  <!-- 功能入口列表 -->
  <view class="menu-list">
    <view
      class="menu-item"
      wx:for="{{menuList}}"
      wx:key="id"
      data-url="{{item.url}}"
      data-tab="{{item.tab}}"
      bindtap="onMenuTap"
    >
      <image class="menu-icon" src="{{item.iconPath}}" mode="aspectFit" />
      <text class="menu-title">{{item.title}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-area" wx:if="{{isLoggedIn}}">
    <text class="logout-btn" bindtap="onLogout">退出登录</text>
  </view>
</view>
