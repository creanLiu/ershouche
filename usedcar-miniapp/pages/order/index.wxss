page {
  background: var(--color-bg-page);
}
.page {
  min-height: 100vh;
}

/* Tabs */
.tabs {
  display: flex;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-divider);
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0 20rpx;
  font-size: 26rpx;
  color: var(--color-text-hint);
  position: relative;
}
.tab-active {
  color: var(--color-primary);
  font-weight: 500;
}
.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

/* 订单列表 */
.order-list {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 订单卡片 */
.order-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  padding: 24rpx;
}
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.order-id {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
}
.status-badge {
  font-size: var(--font-xs);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}
.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}
.status-ongoing {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}
.status-done {
  background: #f6ffed;
  color: #52c41a;
}

/* 车辆信息行 */
.car-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.car-img {
  width: 180rpx;
  height: 130rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
}
.car-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}
.car-title {
  font-size: var(--font-sm);
  color: var(--color-text-primary);
  font-weight: 500;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.car-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.car-tag {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  background: var(--color-bg-page);
  padding: 4rpx 10rpx;
  border-radius: var(--radius-sm);
}
.price-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.price-num {
  font-size: var(--font-lg);
  color: var(--color-primary);
  font-weight: 700;
}
.price-unit {
  font-size: var(--font-xs);
  color: var(--color-primary);
}

/* 卡片底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-divider);
}
.create-time {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
}
.contact-btn {
  font-size: var(--font-sm);
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
  padding: 10rpx 28rpx;
  border-radius: var(--radius-full);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  gap: 20rpx;
}
.empty-state-icon { font-size: 100rpx; }
.empty-state-text {
  font-size: 30rpx;
  color: var(--color-text-hint);
}
