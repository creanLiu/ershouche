page {
  background: var(--color-bg-page);
}

.page {
  padding-bottom: 40rpx;
}

/* 顶部 Header */
.top-header {
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 16rpx 96rpx;
}

.header-logo {
  width: 420rpx;
  height: 168rpx;
}

/* Banner */
.banner-swiper {
  width: 100%;
  height: 340rpx;
}

.banner-item {
  width: 100%;
  height: 340rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* 快捷入口 */
.quick-section {
  background: var(--color-bg-card);
  display: flex;
  padding: 32rpx 16rpx;
  margin-bottom: 16rpx;
}

.quick-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.quick-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: var(--color-primary-bg);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-icon { font-size: 44rpx; }

.quick-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

/* 品牌横滑 */
.brand-section {
  background: var(--color-bg-card);
  margin-bottom: 16rpx;
  padding-bottom: 28rpx;
}

.brand-scroll {
  width: 100%;
}

.brand-list {
  display: flex;
  padding: 0 24rpx;
  gap: 32rpx;
}

.brand-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.brand-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(0,0,0,0.06);
}

.brand-logo {
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
  letter-spacing: -1rpx;
}

.brand-name {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

/* 推荐车辆 */
.recommend-section {
  background: var(--color-bg-card);
}

/* 推荐车辆 - 单列列表 */
.vehicle-list {
  padding: 0 16rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.vehicle-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: row;
  height: 200rpx;
}

.vehicle-cover {
  width: 240rpx;
  height: 200rpx;
  flex-shrink: 0;
  display: block;
}

.vehicle-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.vehicle-name {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vehicle-params {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 10rpx;
}

.vehicle-price {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  color: #FF4500;
  margin-top: auto;
}

.price-num {
  font-size: var(--font-xl);
  font-weight: 700;
}

.price-unit {
  font-size: var(--font-xs);
}
