page {
  background: var(--color-bg-page);
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  gap: 20rpx;
}

.empty-state-icon { font-size: 100rpx; opacity: 0.5; }

.empty-state-text {
  font-size: var(--font-lg);
  color: var(--color-text-primary);
  font-weight: 500;
}

.empty-hint {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
}

.go-browse {
  margin-top: 16rpx;
  width: 240rpx;
}

/* 列表 */
.list-count {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  padding: 20rpx 32rpx;
}

.list {
  display: flex;
  flex-direction: column;
}

.card {
  background: var(--color-bg-card);
  display: flex;
  align-items: center;
  overflow: hidden;
  border-bottom: 1rpx solid var(--color-divider);
  position: relative;
}

.card-img {
  width: 200rpx;
  height: 150rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.card-title {
  font-size: var(--font-sm);
  color: var(--color-text-primary);
  font-weight: 500;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  padding-right: 48rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.card-tag {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  background: var(--color-bg-page);
  padding: 4rpx 10rpx;
  border-radius: var(--radius-sm);
}

.card-price-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-num {
  font-size: var(--font-lg);
  color: var(--color-primary);
  font-weight: 700;
}

.price-unit {
  font-size: var(--font-xs);
  color: var(--color-primary);
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0,0,0,0.25);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 22rpx;
  color: #fff;
}
