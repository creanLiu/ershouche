<view class="page">

  <!-- 顶部操作栏 -->
  <view class="top-bar" wx:if="{{groups.length > 0}}">
    <text class="top-bar-title">共 {{totalCount}} 条记录</text>
    <text class="top-bar-clear" bindtap="onClearAll">清空记录</text>
  </view>

  <!-- 分组时间线 -->
  <view class="group" wx:for="{{groups}}" wx:key="date">
    <view class="group-header">
      <view class="group-dot"></view>
      <text class="group-date">{{item.date}}</text>
    </view>
    <view class="card-list">
      <view
        class="card"
        wx:for="{{item.items}}"
        wx:for-item="car"
        wx:key="id"
        data-id="{{car.id}}"
        bindtap="onCardTap"
      >
        <image class="card-img" src="{{car.image}}" mode="aspectFill" />
        <view class="card-info">
          <text class="card-title">{{car.title}}</text>
          <view class="card-tags">
            <text class="card-tag">{{car.year}}</text>
            <text class="card-tag">{{car.mileage}}</text>
            <text class="card-tag">{{car.location}}</text>
          </view>
          <view class="card-price-row">
            <text class="price-num">{{car.price}}</text>
            <text class="price-unit">万元</text>
          </view>
        </view>
        <text class="card-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{groups.length === 0}}">
    <text class="empty-state-icon">🕐</text>
    <text class="empty-state-text">暂无浏览记录</text>
  </view>

</view>
