page {
  background: var(--color-bg-page);
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部操作栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-divider);
}

.top-bar-title {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
}

.top-bar-clear {
  font-size: var(--font-sm);
  color: var(--color-danger);
}

/* 分组 */
.group { margin-top: 24rpx; }

.group-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 32rpx 16rpx;
}

.group-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  flex-shrink: 0;
}

.group-date {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  font-weight: 500;
}

/* 卡片列表 */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.card {
  background: var(--color-bg-card);
  display: flex;
  align-items: center;
  overflow: hidden;
}

.card-img {
  width: 200rpx;
  height: 150rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.card-title {
  font-size: var(--font-sm);
  color: var(--color-text-primary);
  font-weight: 500;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.card-tag {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  background: var(--color-bg-page);
  padding: 4rpx 10rpx;
  border-radius: var(--radius-sm);
}

.card-price-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-num {
  font-size: var(--font-lg);
  color: var(--color-primary);
  font-weight: 700;
}

.price-unit {
  font-size: var(--font-xs);
  color: var(--color-primary);
}

.card-arrow {
  font-size: 36rpx;
  color: var(--color-border);
  padding-right: 24rpx;
  flex-shrink: 0;
}
