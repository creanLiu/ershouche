page { background: #F5F7FA; }

.header {
  background: linear-gradient(135deg, #FF6B35, #FF4500);
  padding: 24rpx 32rpx 20rpx;
  display: flex;
  flex-direction: column;
}
.header-title { color: #fff; font-size: 36rpx; font-weight: 700; }
.header-sub { color: rgba(255,255,255,0.85); font-size: 24rpx; margin-top: 6rpx; }

.empty { text-align: center; padding: 80rpx 0; color: #999; font-size: 28rpx; }

.vehicle-list {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.vehicle-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: row;
  height: 200rpx;
  position: relative;
}

.special-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: #FF4500;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  z-index: 1;
}

.vehicle-cover {
  width: 240rpx;
  height: 200rpx;
  flex-shrink: 0;
  display: block;
}

.vehicle-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.vehicle-name { font-size: 30rpx; font-weight: 600; color: #1a1a1a; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.vehicle-params {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 10rpx;
}

.vehicle-price { display: flex; align-items: baseline; gap: 4rpx; margin-top: auto; }
.price-num { font-size: 40rpx; font-weight: 700; color: #FF4500; }
.price-unit { font-size: 24rpx; color: #FF4500; }
