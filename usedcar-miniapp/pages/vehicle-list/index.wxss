page {
  background: var(--color-bg-page);
}

.page {
  padding-bottom: 40rpx;
}

/* 筛选栏 */
.filter-bar {
  background: var(--color-bg-card);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  height: 88rpx;
  border-bottom: 1rpx solid var(--color-divider);
  position: sticky;
  top: 0;
  z-index: 20;
}

.filter-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-right: 24rpx;
  border-right: 1rpx solid var(--color-divider);
  margin-right: 24rpx;
}

.filter-icon { font-size: 28rpx; color: var(--color-text-secondary); }
.filter-label { font-size: 28rpx; color: var(--color-text-primary); }

.filter-arrow {
  font-size: 20rpx;
  color: var(--color-text-hint);
  transition: transform 0.2s;
  display: inline-block;
}

.arrow-up { transform: rotate(180deg); }

.sort-tabs {
  display: flex;
  flex: 1;
}

.sort-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.sort-tab-active {
  color: var(--color-primary);
  font-weight: 600;
  border-bottom: 4rpx solid var(--color-primary);
}

/* 筛选面板 */
.filter-panel {
  background: var(--color-bg-card);
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.3s ease;
  border-bottom: 1rpx solid var(--color-divider);
}

.filter-panel-open { max-height: 1200rpx; }

.filter-section { padding: 24rpx 24rpx 0; }

.filter-section-title {
  font-size: 26rpx;
  color: var(--color-text-hint);
  display: block;
  margin-bottom: 16rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.filter-option {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-sm);
  background: var(--color-bg-page);
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.filter-option-active {
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-weight: 500;
}

.filter-actions {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
}

.btn-reset {
  flex: 1;
  height: 80rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.btn-confirm {
  flex: 2;
  height: 80rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

/* 单列列表 */
.vehicle-list {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.vehicle-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: row;
  height: 200rpx;
}

.card-image {
  width: 240rpx;
  height: 200rpx;
  flex-shrink: 0;
  display: block;
}

.card-body {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.card-name {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-params {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  display: block;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-bottom {
  display: flex;
  align-items: baseline;
  margin-top: auto;
}

.card-price {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  color: #FF4500;
}

.price-num {
  font-size: var(--font-xl);
  font-weight: 700;
}

.price-unit {
  font-size: var(--font-xs);
}
